# FlexMatches Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains real keys

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Sign In OAuth Client IDs
# Create at: Google Cloud Console → APIs & Services → Credentials
# - iOS:     "iOS" application type, bundle ID com.flexmatches.app
# - Android: "Android" application type, package com.flexmatches.app + SHA-1 from EAS
# - Web:     "Web application" — paste this Client ID + secret into Supabase Auth → Providers → Google
# See lib/googleAuth.ts header for full setup instructions.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Note: These are set in Supabase Edge Function secrets (not here):
# APPLE_SHARED_SECRET — for IAP receipt verification
# SUPABASE_SERVICE_ROLE_KEY — auto-available in Edge Functions

# Note: Google Places API key is in lib/config.ts (restricted by bundle ID)
